# Stellasaurus environment template.
#
# Copy to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# Every setting in `stellasaurus.common.config.Settings` can be overridden with a
# STELLA_-prefixed variable. Precedence: process env > .env > config/default.toml >
# field defaults. Lines below are commented so the defaults apply until you set them.
# Money values are integer MICRO-USD ($1.00 = 1_000_000).

# --- Credentials (optional in Phase 1; keyless = public market data only) ---
# Kalshi: NOT required for market data (public REST works keyless). Only needed for
# authenticated WebSocket streaming and (later) trading. RSA private key in PEM.
#STELLA_KALSHI_API_KEY_ID=00000000-0000-0000-0000-000000000000
#STELLA_KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private_key.pem
#
# Polymarket US: REQUIRED for real market data (its public endpoints are CDN-cached
# stale; live data needs Ed25519 auth). Get via iOS-app KYC -> polymarket.us/developer.
# The seed is the base64-encoded 32-byte Ed25519 private key.
#STELLA_POLY_ACCESS_KEY=pm_xxxxxxxxxxxxxxxxxxxxxxxx
#STELLA_POLY_ED25519_SEED=BASE64_32_BYTE_SEED==

# --- Dashboard reachability ---
# tailnet (default) = loopback + this host's Tailscale IP; localhost = loopback only;
# all = 0.0.0.0 (LAN-exposed). dashboard_host forces one explicit bind address.
#STELLA_DASHBOARD_EXPOSE=tailnet
#STELLA_DASHBOARD_PORT=8770
#STELLA_DASHBOARD_HOST=

# --- Equivalence engine (Phase 2): Fireworks AI behind BAML ---
# The BAML "Fireworks" client (baml_src/clients.baml) reads these directly. The
# app loads .env at startup and the BAML VSCode playground reads it automatically.
#FIREWORKS_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
#FIREWORKS_API_KEY_BAML=fw_xxxxxxxxxxxxxxxxxxxx
# General Fireworks key (non-BAML usage / fallback for the LLM key):
#FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxx
# Model is pinned in baml_src/clients.baml (change it there to swap models).

# --- Venue endpoints (override only if the defaults move) ---
#STELLA_KALSHI_REST_BASE=https://api.elections.kalshi.com/trade-api/v2
#STELLA_POLY_REST_BASE=https://api.polymarket.us

# --- Storage / seed ---
#STELLA_DB_PATH=data/stella.db
#STELLA_SEED_PATH=seeds/pairs.seed.yaml

# --- Common tunables ---
#STELLA_CATALOG_REFRESH_SECONDS=300
#STELLA_BOOK_STALENESS_MS=2000
#STELLA_REST_POLL_INTERVAL_MS=1000

# --- Risk / sizing (read-only in Phase 1; runtime-editable from Phase 4) ---
#STELLA_THETA_MICROS=20000              # $0.02 min net edge per pair
#STELLA_HURDLE=0.10                     # 10% min annualized return
#STELLA_MAX_BET_VALUE_MICROS=50000000   # $50 cap per single entry

# --- HARD SAFETY GATE ---
# Leave false. Real order submission stays disabled until an explicit, reviewed
# opt-in in a later phase.
#STELLA_LIVE_TRADING_ENABLED=false
